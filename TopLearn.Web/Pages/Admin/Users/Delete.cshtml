@page "{id}"
@using TopLearn.Core.Utils
@model TopLearn.Web.Pages.Admin.Users.DeleteModel
@{
    ViewData["Title"] = "Delete User";
}

<div class="col-md-12">
    <div class="panel panel-danger">
        <div class="panel-heading">
            Delete User
        </div>
        <div class="panel-body">
            <form method="post">
                <input type="hidden" name="UserId" value="@ViewData["UserId"].ToString()"/>
                
                <dl class="dl-horizontal">
                    <dt>UserName :  </dt>
                    <dd>@Model.UserInfoViewModel.UserName</dd>
                    <dt>Email : </dt>
                    <dd>@Model.UserInfoViewModel.Email</dd>
                    <dt>Wallet Balance :</dt>
                    <dd>@Model.UserInfoViewModel.Wallet</dd>
                    <dt>Register Date : </dt>
                    <dd>@Model.UserInfoViewModel.RegisterDate.ToShamsi()</dd>
                    <dt></dt>
                    <dd>
                        <input type="submit" value="Delete" class="btn btn-danger"/>
                    </dd>
                </dl>
            </form>
        </div>
        <!-- /.panel-body -->
    </div>
    <!-- /.panel -->
</div>