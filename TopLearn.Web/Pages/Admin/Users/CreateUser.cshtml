@page
@using TopLearn.Data.Models.Users
@model TopLearn.Web.Pages.Admin.Users.CreateUserModel
@{
    Layout = "Shared/_AdminLayout";
    ViewData["Title"] = "Create User";
    List<Role> roles = ViewData["Roles"] as List<Role>;
}

<div class="row">
    <div class="col-lg-12">
        <h1 class="page-header">Create User</h1>
    </div>
    
</div>

<div class="row">
    <form method="post" enctype="multipart/form-data">
        <div class="col-md-8">
            <div class="panel panel-primary">
                <div class="panel-heading">
                    User Information
                </div>
                
                <div class="panel-body">
                    <div class="form-group">
                        <label>UserName</label>
                        <input type="text" asp-for="CreateUserViewModel.UserName" class="form-control">
                    </div>
                    <div class="form-group">
                        <label>Email</label>
                        <input type="email" asp-for="CreateUserViewModel.Email" class="form-control">
                    </div>
                    <div class="form-group">
                        <label>Password</label>
                        <input type="text" asp-for="CreateUserViewModel.Password" class="form-control">
                    </div>
                    <div class="form-group">
                        <label>Roles</label>
                        @foreach (var item in roles)
                        {
                            <div class="checkbox">
                                <label>
                                    <input type="checkbox" name="SelectedRoles" value="@item.Id">@item.Title
                                </label>
                            </div>
                        }

                    </div>
                    <input type="submit" value="Save" class="btn btn-info"/>
                </div>
                
            </div>
        </div>
        
    </form>
</div>
