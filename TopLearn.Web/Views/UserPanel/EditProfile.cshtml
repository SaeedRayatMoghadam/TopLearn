@model TopLearn.Core.ViewModels.UserPanel.EditUserProfileViewModel

@{
    ViewData["Title"] = User.Identity.Name; 
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ul class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">TopLearn</a></li>
            <li class="breadcrumb-item active" aria-current="page"> Edit Profile</li>
        </ul>
    </nav>
</div>


<main>
    <div class="container">
        <div class="user-account">
            <div class="row">
                
                <partial name="_UserPanelSideBar"/>
                
                
                <div class="col-md-9 col-sm-8 col-xs-12">
                    <section class="user-account-content">
                        <header><h1> Edit Profiel </h1></header>
                        <div class="inner form-layer">
                            <form asp-action="EditProfile" method="post" enctype="multipart/form-data">
                              
                                <div class="row">
                                    <div class="col-md-7 col-sm-8 col-xs-12">
                                        <div class="input-group">
                                            <span class="input-group-addon" id="username"><i class="zmdi zmdi-account"></i></span>
                                            <input type="text" class="form-control" asp-for="UserName" placeholder="User Name" aria-describedby="username">
                                        </div>
                                        <span asp-validation-for="UserName" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-7 col-sm-8 col-xs-12">
                                        <div class="input-group">
                                            <span class="input-group-addon" id="email-address"><i class="zmdi zmdi-email"></i></span>
                                            <input type="text" class="form-control" asp-for="Email" placeholder="Email" aria-describedby="email-address">
                                        </div>
                                        <span asp-validation-for="Email" class="text-danger"></span>
                                    </div>
                                    <div class="col-md-7 col-sm-8 col-xs-12">
                                        <button class="btn btn-success"> Edit </button>
                                    </div>
                                </div>

                            </form>
                        </div>
                    </section>
                </div>

            </div>
        </div>
    </div>
</main>