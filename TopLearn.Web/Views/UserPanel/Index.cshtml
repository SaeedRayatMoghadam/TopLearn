@using TopLearn.Core.Utils
@model TopLearn.Core.ViewModels.UserPanel.UserInfoViewModel

@{
    ViewData["Title"] = User.Identity.Name; 
}

<div class="container">
    <nav aria-label="breadcrumb">
        <ul class="breadcrumb">
            <li class="breadcrumb-item"><a href="/">TopLearn</a></li>
            <li class="breadcrumb-item active" aria-current="page"> User Panel</li>
        </ul>
    </nav>
</div>

<main>
    <div class="container">
        <div class="user-account">
            <div class="row">
                
                <partial name="_UserPanelSideBar"/>
                

                <div class="col-md-9 col-sm-8 col-xs-12">
                    <section class="user-account-content">
                        <header><h1> DashBoard </h1></header>
                        <div class="inner">
                            <div class="account-information">
                                <h3> User Info </h3>
                                <ul>
                                    <li> <i class="zmdi zmdi-assignment-account"></i> User Name :  @Model.UserName </li>
                                    <li> <i class="zmdi zmdi-email"></i> Email : @Model.Email </li>
                                    <li> <i class="zmdi zmdi-calendar-check"></i> Register Date : @Model.RegisterDate.ToShamsi() </li>
                                    <li> <i class="zmdi zmdi-money"></i> Wallet Volume : @Model.Wallet $</li>
                                </ul>
                            </div>
                        </div>
                    </section>
                </div>


            </div>
        </div>
    </div>
</main>
